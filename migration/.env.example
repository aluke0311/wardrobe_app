# Copy this file to `.env` (same folder) and fill in the secrets.
# `.env` is gitignored — it is never committed. Do NOT put secrets here.

# Supabase — Project Settings → API
SUPABASE_URL=https://ofwaxqrwbcixrnjkepuz.supabase.co
SUPABASE_SERVICE_KEY=        # the service_role / secret key (bypasses RLS, local use only)

# Optional: the user_id to stamp every imported row with. Leave blank and the
# script auto-detects it from Supabase Auth (single-user project).
IMPORT_USER_ID=

# Airtable — needed to fetch fresh photo URLs during import.
# Create a personal access token at https://airtable.com/create/tokens
# with scope `data.records:read` on the "CLOTHING BASE CURRENT" base.
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=appK4hX9DJYTGFGYb
